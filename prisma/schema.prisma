generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  suspended
  invited
  canceled
}

enum AdminRole {
  super_admin
  admin
  operator
}

enum PointSourceType {
  auto
  manual
  external
}

enum PointTransactionType {
  grant
  adjust
  external_import
  use
  expire
  reversal
}

enum ContractStatus {
  pending
  active
  canceled
  suspended
}

enum RewardStatus {
  scheduled
  granted
  canceled
  reversed
}

model User {
  id            BigInt     @id @default(autoincrement())
  memberCode    String     @unique @db.VarChar(50)
  name          String     @db.VarChar(255)
  nameKana      String?    @db.VarChar(255)
  email         String     @unique @db.VarChar(255)
  passwordHash  String     @db.VarChar(255)
  phone         String?    @db.VarChar(30)
  postalCode    String?    @db.VarChar(10)
  address       String?    @db.VarChar(500)
  status        UserStatus @default(active)
  avatarUrl     String?    @db.VarChar(500)
  referralCode  String?    @unique @db.VarChar(30)
  referrerContracts MobileContract[] @relation("ReferrerContracts")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLoginAt   DateTime?
  canceledAt    DateTime?

  referrals     UserReferral[]   @relation("ReferralsOfUser")
  referredBy    UserReferral[]   @relation("ReferrerOfUser")
  contracts     MobileContract[]
  travelSubs    TravelSubscription[]
  pointWallet   PointWallet?
  pointLogs     PointTransaction[]
  pointUsages   PointUsage[]
  orders        Order[]
  contactInquiries ContactInquiry[]
  vpPhoneApplications VpPhoneApplication[]
  mlmMember       MlmMember?
  mlmRegistration MlmRegistration?
}

model Admin {
  id           BigInt    @id @default(autoincrement())
  name         String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  role         AdminRole @default(admin)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model UserReferral {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt
  referrerUserId BigInt
  relationType   String    @default("direct") @db.VarChar(20)
  isActive       Boolean   @default(true)
  validFrom      DateTime
  validTo        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User @relation("ReferralsOfUser", fields: [userId], references: [id], onDelete: Cascade)
  referrer User @relation("ReferrerOfUser", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([referrerUserId])
}

model ReferralHistory {
  id                BigInt    @id @default(autoincrement())
  userId            BigInt
  referrerUserId    BigInt
  actionType        String    @db.VarChar(50)
  validFrom         DateTime?
  validTo           DateTime?
  operatedByAdminId BigInt?
  note              String?   @db.VarChar(255)
  createdAt         DateTime  @default(now())
}

model Menu {
  id          BigInt   @id @default(autoincrement())
  title       String   @unique @db.VarChar(255)
  subtitle    String?  @db.VarChar(255)
  iconType    String?  @db.VarChar(50)
  imageUrl    String?  @db.VarChar(500)
  linkUrl     String   @default("") @db.VarChar(500)
  menuType    String   @default("url") @db.VarChar(50)
  contentData String?  @db.Text
  isActive    Boolean  @default(true)
  isHighlight Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactInquiry {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(100)
  phone      String    @db.VarChar(30)
  email      String    @db.VarChar(255)
  content    String    @db.Text
  menuTitle  String?   @db.VarChar(255)
  isRead     Boolean   @default(false)
  readAt     DateTime?
  readByAdminId BigInt?
  userId     BigInt?
  createdAt  DateTime  @default(now())

  user       User?     @relation(fields: [userId], references: [id])
}

model MediaFile {
  id               BigInt   @id @default(autoincrement())
  fileName         String   @db.VarChar(255)
  originalFileName String   @db.VarChar(255)
  contentType      String   @db.VarChar(100)
  fileSize         BigInt
  storageDisk      String   @db.VarChar(100)
  storagePath      String   @db.VarChar(500)
  publicUrl        String   @db.VarChar(500)
  uploadedByType   String   @db.VarChar(20)
  uploadedById     BigInt?
  createdAt        DateTime @default(now())
}

model ContractReferralReward {
  id                    BigInt       @id @default(autoincrement())
  contractId            BigInt
  contractedUserId      BigInt
  referrerUserId        BigInt
  referralRelationId    BigInt
  rewardMonth           String       @db.Char(7)
  baseMonthlyFee        Decimal      @db.Decimal(10, 2)
  rewardRate            Decimal      @db.Decimal(5, 4)
  rewardPoints          Int
  calculationTargetDate DateTime
  status                RewardStatus @default(scheduled)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  contract MobileContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, referrerUserId, rewardMonth])
  @@index([contractedUserId])
  @@index([referrerUserId])
}

model MonthlyRewardRun {
  id                BigInt   @id @default(autoincrement())
  rewardMonth       String   @db.Char(7)
  closingDate       DateTime
  mode              String   @db.VarChar(20)
  totalContracts    Int      @default(0)
  totalReferrers    Int      @default(0)
  totalRewardPoints Int      @default(0)
  executedByAdminId BigInt?
  createdAt         DateTime @default(now())
}

model PointWallet {
  id                     BigInt   @id @default(autoincrement())
  userId                 BigInt   @unique
  autoPointsBalance      Int      @default(0)
  manualPointsBalance    Int      @default(0)
  externalPointsBalance  Int      @default(0)
  availablePointsBalance Int      @default(0)
  usedPointsBalance      Int      @default(0)
  expiredPointsBalance   Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PointTransaction {
  id              BigInt               @id @default(autoincrement())
  userId          BigInt
  transactionType PointTransactionType
  pointSourceType PointSourceType
  points          Int
  balanceAfter    Int
  relatedUserId   BigInt?
  relatedContractId BigInt?
  description     String?              @db.VarChar(255)
  occurredAt      DateTime
  createdByType   String               @db.VarChar(20)
  createdById     BigInt?
  createdAt       DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([relatedContractId])
}

model PointUsage {
  id                  BigInt   @id @default(autoincrement())
  userId              BigInt
  orderId             BigInt?
  usedAutoPoints      Int      @default(0)
  usedManualPoints    Int      @default(0)
  usedExternalPoints  Int      @default(0)
  totalUsedPoints     Int
  usedAt              DateTime
  createdAt           DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
}

model Product {
  id          BigInt   @id @default(autoincrement())
  code        String?  @db.VarChar(50)
  name        String   @unique @db.VarChar(255)
  description String?  @db.VarChar(500)
  price       Int
  imageUrl    String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt
  orderNumber    String   @unique @db.VarChar(100)
  status         String   @db.VarChar(30)
  subtotalAmount Int
  usedPoints     Int      @default(0)
  totalAmount    Int
  orderedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         OrderItem[]
  pointUsages   PointUsage[]
  shippingLabel ShippingLabel?

  @@index([userId])
}

model OrderItem {
  id          BigInt   @id @default(autoincrement())
  orderId     BigInt
  productId   BigInt
  productName String   @db.VarChar(255)
  unitPrice   Int
  quantity    Int
  lineAmount  Int
  createdAt   DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model TravelSubscription {
  id             BigInt         @id @default(autoincrement())
  userId         BigInt
  planName       String         @db.VarChar(255)
  level          Int            @default(1)           // 1〜5
  pricingTier    String         @default("early") @db.VarChar(20) // "early"=初回50名, "standard"=51名〜
  monthlyFee     Decimal        @db.Decimal(10, 2)
  status         ContractStatus @default(pending)
  forceStatus    String         @default("none") @db.VarChar(20) // "none"|"forced_active"|"forced_inactive"
  startedAt      DateTime?
  confirmedAt    DateTime?
  canceledAt     DateTime?
  note           String?        @db.VarChar(500)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AdminAuditLog {
  id          BigInt   @id @default(autoincrement())
  adminId     BigInt?
  actionType  String   @db.VarChar(100)
  targetTable String   @db.VarChar(100)
  targetId    String?  @db.VarChar(100)
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
}

model SiteSetting {
  id           BigInt   @id @default(autoincrement())
  settingKey   String   @unique @db.VarChar(100)
  settingValue String?  @db.VarChar(1000)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  tag         String   @default("notice") // "important" | "campaign" | "new" | "notice"
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcements")
}
enum VpPhoneApplicationStatus {
  pending
  reviewing
  contracted
  rejected
  canceled
}

model VpPhoneApplication {
  id              BigInt                     @id @default(autoincrement())
  userId          BigInt
  // 申込者情報
  nameKanji       String                     @db.VarChar(100)
  nameKana        String                     @db.VarChar(100)
  email           String                     @db.VarChar(255)
  password        String?                    @db.VarChar(255)
  phone           String                     @db.VarChar(30)
  birthDate       String                     @db.VarChar(20)
  gender          String                     @db.VarChar(10)
  lineId          String?                    @db.VarChar(100)
  lineDisplayName String?                    @db.VarChar(100)
  // 紹介者情報
  referrerCode    String?                    @db.VarChar(100)
  referrerName    String?                    @db.VarChar(100)
  // 希望プラン種別: voice=音声回線契約, data=大容量データ回線契約
  contractType    String?                    @db.VarChar(50)
  desiredPlan     String?                    @db.VarChar(255)
  // 管理情報
  status          VpPhoneApplicationStatus   @default(pending)
  adminNote       String?                    @db.VarChar(500)
  reviewedAt      DateTime?
  reviewedByAdminId BigInt?
  contractedAt    DateTime?
  // 紐づく携帯契約（審査完了後に設定）
  mobileContractId BigInt?                   @unique
  // 手動申請ステータス管理
  applicationSubmitted Boolean               @default(false)  // 事務局側での申請済みフラグ
  applicationSubmittedAt DateTime?                            // 申請日時
  applicationSubmittedByAdminId BigInt?                       // 申請した管理者ID
  officeEmail     String?                    @db.VarChar(255) // 事務局側申請メールアドレス
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mobileContract MobileContract? @relation(fields: [mobileContractId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("vp_phone_applications")
}

model MobileContract {
  id              BigInt         @id @default(autoincrement())
  userId          BigInt
  referrerId      BigInt?
  contractNumber  String?        @db.VarChar(100)
  planName        String         @db.VarChar(255)
  monthlyFee      Decimal        @default(0) @db.Decimal(10, 2)
  status          ContractStatus @default(pending)
  startedAt       DateTime?
  confirmedAt     DateTime?
  canceledAt      DateTime?
  note            String?        @db.VarChar(500)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrer         User?                    @relation("ReferrerContracts", fields: [referrerId], references: [id])
  referralRewards  ContractReferralReward[]
  vpPhoneApplication VpPhoneApplication?

  @@index([userId])
  @@index([status])
  @@index([referrerId])
  @@map("mobile_contracts")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// 発送伝票モデル
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

enum ShippingCarrier {
  yamato   // ヤマト運輸
  sagawa   // 佐川急便
  japan_post // 日本郵便
}

enum ShippingLabelStatus {
  pending   // 未印刷
  printed   // 印刷済み
  shipped   // 発送済み
  canceled  // キャンセル
}

enum DeliveryType {
  voucher           // 金券
  hand_delivery     // 手渡し
  autoship          // オートシップ
  cooling_off       // クーリング・オフ
  exchange          // 交換
  cancel            // キャンセル
  other_order       // 他発注
  combined_reserve  // 合わせ予約
  additional        // 追加
  staff_delivery    // 社員配達
  staff_list        // 社員配達リスト
  web               // Web
  present           // プレゼント
  mid_cancel        // 中途解約
}

enum CustomerRank {
  sequential        // 連続
  regular           // 定期
  other             // その他
  member            // 会員
  card              // カード
  associate         // 準会員
  convenience       // コンビニ
  other_delivery    // その他配達
}

enum OrderMethod {
  handwritten       // 手書
  postcard          // ハガキ
  normal            // 通常
  overseas          // 海外
}

enum DeliveryCenter {
  hand_delivery     // 手渡し
  big14_center      // 第14Bigセンター
  big2_center       // 第2Bigセンター
  other             // その他
}

/// 発送伝票（注文ごとに生成）
model ShippingLabel {
  id              BigInt              @id @default(autoincrement())
  orderId         BigInt              @unique
  orderNumber     String              @db.VarChar(100)
  carrier         ShippingCarrier     @default(yamato)
  trackingNumber  String?             @db.VarChar(100)
  status          ShippingLabelStatus @default(pending)
  // 送り先情報（注文時点のスナップショット）
  recipientName   String              @db.VarChar(255)
  recipientPhone  String              @db.VarChar(30)
  recipientPostal String              @db.VarChar(10)
  recipientAddress String             @db.VarChar(500)
  recipientFax    String?             @db.VarChar(30)
  recipientCompany String?            @db.VarChar(255)
  // 差出人（会社固定）
  senderName      String              @default("CLAIRホールディングス株式会社") @db.VarChar(255)
  senderPostal    String              @default("020-0026") @db.VarChar(10)
  senderAddress   String              @default("岩手県盛岡市開運橋通5-6 第五菱和ビル5F") @db.VarChar(500)
  senderPhone     String              @default("019-681-3667") @db.VarChar(30)
  // 品名・重量
  itemDescription String              @default("VIOLA Pure 翠彩-SUMISAI-") @db.VarChar(255)
  itemCount       Int                 @default(1)
  // 配送オプション
  deliveryType    String?             @db.VarChar(50)  // 金券/手渡し/オートシップ/クーリング・オフ等
  deliveryTime    String?             @db.VarChar(50)  // 配達希望時間帯
  shippingFee     Int                 @default(0)      // 送料
  shippingFeeType String              @default("free") @db.VarChar(20) // free/paid/cod
  customerRank    String?             @db.VarChar(50)  // 顧客ランク(連続/定期/その他/会員/カード/準会員/コンビニ/その他配達)
  autoshipNo      String?             @db.VarChar(50)  // オートシップ番号
  memberJoinDate  DateTime?                           // 入会日
  birthDate       DateTime?                           // 生年月日
  // 注文者・法人情報
  ordererName     String?             @db.VarChar(255) // 注文者名
  legalEntityName String?             @db.VarChar(255) // 法人名
  representative  String?             @db.VarChar(255) // 法人代表者
  ordererPhone    String?             @db.VarChar(30)  // 注文者電話番号
  ordererFax      String?             @db.VarChar(30)  // 注文者FAX
  ordererBirthDate DateTime?                          // 注文者生年月日
  initialContact  String?             @db.VarChar(100) // 初回接触方法
  // 配送センター・記録
  deliveryCenter  String?             @db.VarChar(100) // 配送センター(手渡し/第14Bigセンター/第2Bigセンター)
  voucherNumber   String?             @db.VarChar(100) // 金券番号
  recordNumber    String?             @db.VarChar(100) // 記録(伝票)番号
  desiredDeliveryDate DateTime?                       // 配送希望日
  // 受注方法
  orderMethod     String?             @db.VarChar(50)  // 手書/ハガキ/通常/海外
  // 印刷・発送管理
  printedAt       DateTime?
  shippedAt       DateTime?
  printedByAdminId BigInt?
  note            String?             @db.VarChar(500)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  order           Order               @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([carrier])
  @@index([deliveryType])
  @@map("shipping_labels")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MLM（CLAIR仕様）専用モデル
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

/// MLM専用登録情報（Userと1:1）
model MlmRegistration {
  id                  BigInt    @id @default(autoincrement())
  userId              BigInt    @unique
  // 基本情報
  nickname            String?   @db.VarChar(100)
  birthDate           String?   @db.VarChar(20)   // "YYYY-MM-DD"
  // 概要書面番号
  disclosureDocNumber String?   @db.VarChar(100)
  // 報酬受取り口座情報
  bankName            String?   @db.VarChar(100)
  bankBranch          String?   @db.VarChar(100)
  bankAccountType     String?   @default("普通") @db.VarChar(20)  // 普通/当座
  bankAccountNumber   String?   @db.VarChar(20)
  bankAccountHolder   String?   @db.VarChar(100)
  // 配送先住所（登録住所と異なる場合）
  deliveryPostalCode  String?   @db.VarChar(10)
  deliveryAddress     String?   @db.VarChar(500)
  deliveryName        String?   @db.VarChar(255)  // 宛名（法人名など）
  // 同意・確認
  agreedToTerms       Boolean   @default(false)
  agreedAt            DateTime?
  // 紹介URL経由での登録かどうか
  registeredViaMLM    Boolean   @default(false)
  mlmReferrerId       BigInt?   // 紹介したMLM会員のID
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mlm_registrations")
}

/// 会員タイプ（ビジネス会員 / 愛用会員）
enum MlmMemberType {
  business   // ビジネス会員（ボーナス取得権あり）
  preferred  // 愛用会員（ボーナス取得権なし）
}

/// 会員ステータス
enum MlmMemberStatus {
  active      // 活動中
  autoship    // オートシップのみ
  lapsed      // 失効
  suspended   // 停止
  withdrawn   // 退会
  midCancel   // 中途解約
}

/// ボーナス計算実行ステータス
enum BonusRunStatus {
  draft      // 下書き（計算中）
  confirmed  // 確定（結果公開済み）
  canceled   // 取消
}

/// ボーナス種別
enum BonusType {
  direct       // ダイレクトボーナス
  unilevel     // ユニレベルボーナス
  structure    // 組織構築ボーナス
  savings      // 貯金ボーナス
}

/// 支払い方法
enum PaymentMethod {
  credit_card    // クレジットカード（クレディックス）
  bank_transfer  // 口座振替（三菱UFJファクター）
  bank_payment   // 銀行振込
}

/// 購入ステータス
enum PurchaseStatus {
  autoship       // オートシップ
  one_time       // 都度購入
  new_member     // 新規登録者
  cooling_off    // クーリングオフ
  canceled       // キャンセル
  out_of_stock   // 欠品
  out_of_stock_minus_1 // 欠品欠1
  company_sale   // 社販
  other          // その他
}

/// MLM会員情報（CLAIRホールディングス仕様）
model MlmMember {
  id                BigInt          @id @default(autoincrement())
  userId            BigInt          @unique
  memberCode        String          @unique @db.VarChar(50)  // 6桁-枝番（例: 123456-01）
  memberType        MlmMemberType   @default(business)
  status            MlmMemberStatus @default(active)
  // 組織構造
  uplineId          BigInt?                                  // 直上者（マトリックス）
  referrerId        BigInt?                                  // 紹介者（ユニレベル）
  matrixPosition    Int             @default(0)              // 直下での位置（1〜6）
  // レベル関連
  currentLevel      Int             @default(0)              // 0=なし, 1〜5
  titleLevel        Int             @default(0)              // 称号レベル（過去最高）
  conditionAchieved Boolean         @default(false)          // 条件達成フラグ
  forceActive       Boolean         @default(false)          // 強制アクティブ
  forceLevel        Int?                                     // 強制レベル
  // 契約日
  contractDate      DateTime?                                // 契約締結日（アクティブ判定①）
  // オートシップ
  autoshipEnabled   Boolean         @default(false)
  autoshipStartDate DateTime?                                // オートシップ開始日
  autoshipStopDate  DateTime?                                // オートシップ停止日
  autoshipSuspendMonths String?     @db.VarChar(100)         // カンマ区切り "2025-01,2025-02"
  // 支払い方法
  paymentMethod     PaymentMethod   @default(credit_card)    // 支払い方法
  // 貯金ポイント累計
  savingsPoints     Int             @default(0)
  // 銀行情報
  bankCode          String?         @db.VarChar(10)
  bankName          String?         @db.VarChar(100)
  branchCode        String?         @db.VarChar(10)
  branchName        String?         @db.VarChar(100)
  accountType       String?         @db.VarChar(10)   // 普通/当座
  accountNumber     String?         @db.VarChar(20)
  accountHolder     String?         @db.VarChar(100)
  // 法人情報
  companyName       String?         @db.VarChar(255)
  companyNameKana   String?         @db.VarChar(255)
  // 個人情報追加
  birthDate         DateTime?
  gender            String?         @db.VarChar(10)   // male/female/other
  mobile            String?         @db.VarChar(30)
  prefecture        String?         @db.VarChar(50)
  city              String?         @db.VarChar(100)
  address1          String?         @db.VarChar(255)
  address2          String?         @db.VarChar(255)
  note              String?         @db.VarChar(500)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  upline            MlmMember?      @relation("MatrixDownline", fields: [uplineId], references: [id])
  downlines         MlmMember[]     @relation("MatrixDownline")
  referrer          MlmMember?      @relation("UniLevelReferrals", fields: [referrerId], references: [id])
  referrals         MlmMember[]     @relation("UniLevelReferrals")
  purchases         MlmPurchase[]
  bonusResults      BonusResult[]   @relation("BonusRecipient")
  autoShipOrders    AutoShipOrder[] @relation("AutoShipOrders")
  bonusAdjustments  BonusAdjustment[]
  bonusShortagePayments BonusShortagePayment[]

  @@index([uplineId])
  @@index([referrerId])
  @@index([status])
  @@map("mlm_members")
}

/// MLM購入記録（ポイント計算用）
model MlmPurchase {
  id              BigInt         @id @default(autoincrement())
  mlmMemberId     BigInt
  productCode     String         @db.VarChar(20)   // 商品コード (s1000, 1000, 1002, 2000 等)
  productName     String         @db.VarChar(255)
  quantity        Int            @default(1)
  unitPrice       Int                              // 税込金額（円）
  points          Int            @default(0)       // 商品ポイント
  totalPoints     Int            @default(0)       // quantity × points
  purchaseStatus  PurchaseStatus @default(one_time) // 購入ステータス
  purchaseMonth   String         @db.Char(7)       // "YYYY-MM"
  purchasedAt     DateTime
  createdAt       DateTime       @default(now())

  mlmMember       MlmMember      @relation(fields: [mlmMemberId], references: [id], onDelete: Cascade)

  @@index([mlmMemberId])
  @@index([purchaseMonth])
  @@index([purchaseStatus])
  @@map("mlm_purchases")
}

/// ボーナス計算実行記録（月次）
model BonusRun {
  id                  BigInt          @id @default(autoincrement())
  bonusMonth          String          @db.Char(7)       // "YYYY-MM"
  closingDate         DateTime                          // 締め日
  status              BonusRunStatus  @default(draft)
  // 集計結果
  totalMembers        Int             @default(0)
  totalActiveMembers  Int             @default(0)
  totalBonusAmount    Int             @default(0)       // 総ボーナス支払額（円）
  paymentAdjustmentRate Float?                          // 支払い調整率（%）
  capAdjustmentAmount Int             @default(0)       // CAP調整額（円）
  // 実行情報
  executedByAdminId   BigInt?
  confirmedAt         DateTime?
  note                String?         @db.VarChar(500)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  results             BonusResult[]
  adjustments         BonusAdjustment[]
  shortagePayments    BonusShortagePayment[]

  @@unique([bonusMonth])
  @@map("bonus_runs")
}

/// ボーナス計算結果（会員ごと）
model BonusResult {
  id                  BigInt      @id @default(autoincrement())
  bonusRunId          BigInt
  mlmMemberId         BigInt
  bonusMonth          String      @db.Char(7)       // "YYYY-MM"
  // アクティブ判定
  isActive            Boolean     @default(false)
  selfPurchasePoints  Int         @default(0)       // 自己購入pt
  groupPoints         Int         @default(0)       // グループpt（7段合計）
  directActiveCount   Int         @default(0)       // 直接紹介アクティブ数
  // レベル
  achievedLevel       Int         @default(0)       // 当月実績レベル (0〜5)
  previousTitleLevel  Int         @default(0)       // 旧レベル（計算前の称号）
  newTitleLevel       Int         @default(0)       // 新称号レベル（計算後）
  // ボーナス金額（円）
  directBonus         Int         @default(0)       // ダイレクトボーナス
  unilevelBonus       Int         @default(0)       // ユニレベルボーナス
  rankUpBonus         Int         @default(0)       // ランクアップボーナス
  shareBonus          Int         @default(0)       // シェアボーナス
  structureBonus      Int         @default(0)       // 組織構築ボーナス
  savingsBonus        Int         @default(0)       // 貯金ボーナス
  carryoverAmount     Int         @default(0)       // 繰越金
  adjustmentAmount    Int         @default(0)       // 調整金
  otherPositionAmount Int         @default(0)       // 他ポジション
  // 支払い計算
  amountBeforeAdjustment Int      @default(0)       // 支払調整前取得額
  paymentAdjustmentRate  Float?                     // 支払調整率（%）
  paymentAdjustmentAmount Int     @default(0)       // 支払調整額
  finalAmount         Int         @default(0)       // 取得額（調整後）
  consumptionTax      Int         @default(0)       // 10%消費税（内税）
  withholdingTax      Int         @default(0)       // 源泉所得税
  shortageAmount      Int         @default(0)       // 過不足金
  otherPositionShortage Int       @default(0)       // 他ポジション過不足金
  serviceFee          Int         @default(0)       // 事務手数料
  paymentAmount       Int         @default(0)       // 支払額
  // 組織データ
  groupActiveCount    Int         @default(0)       // グループACT
  minLinePoints       Int         @default(0)       // 最小系列pt
  lineCount           Int         @default(0)       // 系列数
  level1Lines         Int         @default(0)       // LV.1達成系列数
  level2Lines         Int         @default(0)       // LV.2達成系列数
  level3Lines         Int         @default(0)       // LV.3達成系列数
  forcedLevel         Int         @default(0)       // 強制レベル
  conditions          String?     @db.VarChar(500)  // 達成条件詳細
  savingsPoints       Int         @default(0)       // 貯金ポイント累計
  // ユニレベルボーナス段数内訳（JSON）
  unilevelDetail      Json?                         // { "1": pt, "2": pt, ... }
  savingsPointsAdded  Int         @default(0)       // 今月追加貯金pt
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  bonusRun            BonusRun    @relation(fields: [bonusRunId], references: [id], onDelete: Cascade)
  mlmMember           MlmMember   @relation("BonusRecipient", fields: [mlmMemberId], references: [id], onDelete: Cascade)

  @@unique([bonusRunId, mlmMemberId])
  @@index([bonusMonth])
  @@index([mlmMemberId])
  @@map("bonus_results")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// オートシップ管理モデル
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

/// 支払い方法
enum AutoShipPaymentMethod {
  credit_card   // クレジットカード（クレディックス）
  bank_transfer // 口座振替（三菱UFJファクター）
}

/// オートシップ実行ステータス
enum AutoShipRunStatus {
  draft      // 下書き（伝票作成済み・未決済）
  exported   // CSV出力済み（決済会社へ送付済み）
  importing  // 決済結果取込中
  completed  // 決済完了・アクティブ反映済み
  canceled   // キャンセル
}

/// オートシップ注文ステータス
enum AutoShipOrderStatus {
  pending        // 未決済
  paid           // 決済完了
  failed         // 決済失敗
  canceled       // キャンセル
  delivered      // 発送済み
}

/// 月次オートシップ実行（月ごと・支払い方法ごと）
model AutoShipRun {
  id              BigInt              @id @default(autoincrement())
  targetMonth     String              @db.Char(7)       // "YYYY-MM"
  paymentMethod   AutoShipPaymentMethod
  status          AutoShipRunStatus   @default(draft)
  // 集計
  totalCount      Int                 @default(0)
  paidCount       Int                 @default(0)
  failedCount     Int                 @default(0)
  totalAmount     Int                 @default(0)       // 合計金額（円）
  // 実行情報
  exportedAt      DateTime?
  importedAt      DateTime?
  completedAt     DateTime?
  executedByAdminId BigInt?
  note            String?             @db.VarChar(500)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  orders          AutoShipOrder[]

  @@unique([targetMonth, paymentMethod])
  @@index([targetMonth])
  @@map("autoship_runs")
}

/// オートシップ注文（会員ごとの月次決済伝票）
model AutoShipOrder {
  id              BigInt              @id @default(autoincrement())
  autoShipRunId   BigInt
  mlmMemberId     BigInt
  targetMonth     String              @db.Char(7)       // "YYYY-MM"
  paymentMethod   AutoShipPaymentMethod
  // 会員情報スナップショット（出力時点）
  memberCode      String              @db.VarChar(50)
  memberName      String              @db.VarChar(255)
  memberNameKana  String?             @db.VarChar(255)
  memberPhone     String?             @db.VarChar(30)
  memberEmail     String?             @db.VarChar(255)
  memberPostal    String?             @db.VarChar(10)
  memberAddress   String?             @db.VarChar(500)
  // 商品情報
  productCode     String              @default("2000") @db.VarChar(20)
  productName     String              @default("VIOLA Pure 翠彩-SUMISAI-") @db.VarChar(255)
  quantity        Int                 @default(1)
  unitPrice       Int                 @default(16500)   // 税込
  totalAmount     Int                 @default(16500)
  points          Int                 @default(150)
  // 決済情報
  status          AutoShipOrderStatus @default(pending)
  paidAt          DateTime?
  failReason      String?             @db.VarChar(255)
  // クレジットカード用
  creditCardId    String?             @db.VarChar(100)  // クレディックス顧客ID
  // 口座振替用
  bankCode        String?             @db.VarChar(10)
  bankName        String?             @db.VarChar(100)
  branchCode      String?             @db.VarChar(10)
  branchName      String?             @db.VarChar(100)
  accountType     String?             @db.VarChar(10)   // 普通/当座
  accountNumber   String?             @db.VarChar(20)
  accountHolder   String?             @db.VarChar(100)
  // 納品書
  deliveryNoteId  BigInt?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  autoShipRun     AutoShipRun         @relation(fields: [autoShipRunId], references: [id], onDelete: Cascade)
  mlmMember       MlmMember           @relation("AutoShipOrders", fields: [mlmMemberId], references: [id], onDelete: Cascade)
  deliveryNote    DeliveryNote?       @relation(fields: [deliveryNoteId], references: [id])

  @@unique([autoShipRunId, mlmMemberId])
  @@index([targetMonth])
  @@index([status])
  @@index([mlmMemberId])
  @@map("autoship_orders")
}

/// 納品書
model DeliveryNote {
  id              BigInt              @id @default(autoincrement())
  noteNumber      String              @unique @db.VarChar(50)  // 納品書番号 DN-YYYYMM-0001
  targetMonth     String              @db.Char(7)
  // 宛先
  recipientName   String              @db.VarChar(255)
  recipientPostal String?             @db.VarChar(10)
  recipientAddress String?            @db.VarChar(500)
  // 商品
  productCode     String              @db.VarChar(20)
  productName     String              @db.VarChar(255)
  quantity        Int                 @default(1)
  unitPrice       Int
  totalAmount     Int
  // 差出人（会社固定）
  senderName      String              @default("CLAIRホールディングス株式会社") @db.VarChar(255)
  senderPostal    String              @default("020-0026") @db.VarChar(10)
  senderAddress   String              @default("岩手県盛岡市開運橋通5-6 第五菱和ビル5F") @db.VarChar(500)
  senderPhone     String              @default("019-681-3667") @db.VarChar(30)
  issuedAt        DateTime            @default(now())
  createdAt       DateTime            @default(now())

  autoShipOrders  AutoShipOrder[]

  @@index([targetMonth])
  @@map("delivery_notes")
}

// ボーナス調整金（手動入力）
model BonusAdjustment {
  id              BigInt   @id @default(autoincrement())
  bonusRunId      BigInt
  mlmMemberId     BigInt
  amount          Int                      // 調整金額（円）
  comment         String?  @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bonusRun        BonusRun  @relation(fields: [bonusRunId], references: [id], onDelete: Cascade)
  mlmMember       MlmMember @relation(fields: [mlmMemberId], references: [id], onDelete: Cascade)

  @@index([bonusRunId])
  @@index([mlmMemberId])
  @@map("bonus_adjustments")
}

// ボーナス過不足金（源泉対象外）
model BonusShortagePayment {
  id              BigInt   @id @default(autoincrement())
  bonusRunId      BigInt
  mlmMemberId     BigInt
  amount          Int                      // 過不足金額（円）
  comment         String?  @db.VarChar(500)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bonusRun        BonusRun  @relation(fields: [bonusRunId], references: [id], onDelete: Cascade)
  mlmMember       MlmMember @relation(fields: [mlmMemberId], references: [id], onDelete: Cascade)

  @@index([bonusRunId])
  @@index([mlmMemberId])
  @@map("bonus_shortage_payments")
}

// 貯金ボーナス設定
model SavingsBonusConfig {
  id                      Int      @id @default(autoincrement())
  registrationRate        Float    @default(20.0)    // 登録時（デフォルト20%）
  autoshipRate            Float    @default(5.0)     // オートシップ（デフォルト5%）
  bonusRate               Float    @default(3.0)     // ボーナス（デフォルト3%）
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())

  @@map("savings_bonus_config")
}

