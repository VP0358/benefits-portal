generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  active
  suspended
  invited
  canceled
}

enum AdminRole {
  super_admin
  admin
  operator
}

enum PointSourceType {
  auto
  manual
  external
}

enum PointTransactionType {
  grant
  adjust
  external_import
  use
  expire
  reversal
}

enum ContractStatus {
  pending
  active
  canceled
  suspended
}

enum RewardStatus {
  scheduled
  granted
  canceled
  reversed
}

model User {
  id            BigInt     @id @default(autoincrement())
  memberCode    String     @unique @db.VarChar(50)
  name          String     @db.VarChar(255)
  nameKana      String?    @db.VarChar(255)
  email         String     @unique @db.VarChar(255)
  passwordHash  String     @db.VarChar(255)
  phone         String?    @db.VarChar(30)
  postalCode    String?    @db.VarChar(10)
  address       String?    @db.VarChar(500)
  status        UserStatus @default(active)
  avatarUrl     String?    @db.VarChar(500)
  referralCode  String?    @unique @db.VarChar(30)
  referrerContracts MobileContract[] @relation("ReferrerContracts")
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  lastLoginAt   DateTime?
  canceledAt    DateTime?

  referrals     UserReferral[]   @relation("ReferralsOfUser")
  referredBy    UserReferral[]   @relation("ReferrerOfUser")
  contracts     MobileContract[]
  travelSubs    TravelSubscription[]
  pointWallet   PointWallet?
  pointLogs     PointTransaction[]
  pointUsages   PointUsage[]
  orders        Order[]
  contactInquiries ContactInquiry[]
  vpPhoneApplications VpPhoneApplication[]
  mlmMember     MlmMember?
}

model Admin {
  id           BigInt    @id @default(autoincrement())
  name         String    @db.VarChar(255)
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  role         AdminRole @default(admin)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model UserReferral {
  id             BigInt    @id @default(autoincrement())
  userId         BigInt
  referrerUserId BigInt
  relationType   String    @default("direct") @db.VarChar(20)
  isActive       Boolean   @default(true)
  validFrom      DateTime
  validTo        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user     User @relation("ReferralsOfUser", fields: [userId], references: [id], onDelete: Cascade)
  referrer User @relation("ReferrerOfUser", fields: [referrerUserId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([referrerUserId])
}

model ReferralHistory {
  id                BigInt    @id @default(autoincrement())
  userId            BigInt
  referrerUserId    BigInt
  actionType        String    @db.VarChar(50)
  validFrom         DateTime?
  validTo           DateTime?
  operatedByAdminId BigInt?
  note              String?   @db.VarChar(255)
  createdAt         DateTime  @default(now())
}

model Menu {
  id          BigInt   @id @default(autoincrement())
  title       String   @unique @db.VarChar(255)
  subtitle    String?  @db.VarChar(255)
  iconType    String?  @db.VarChar(50)
  imageUrl    String?  @db.VarChar(500)
  linkUrl     String   @default("") @db.VarChar(500)
  menuType    String   @default("url") @db.VarChar(50)
  contentData String?  @db.Text
  isActive    Boolean  @default(true)
  isHighlight Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContactInquiry {
  id         BigInt    @id @default(autoincrement())
  name       String    @db.VarChar(100)
  phone      String    @db.VarChar(30)
  email      String    @db.VarChar(255)
  content    String    @db.Text
  menuTitle  String?   @db.VarChar(255)
  isRead     Boolean   @default(false)
  readAt     DateTime?
  readByAdminId BigInt?
  userId     BigInt?
  createdAt  DateTime  @default(now())

  user       User?     @relation(fields: [userId], references: [id])
}

model MediaFile {
  id               BigInt   @id @default(autoincrement())
  fileName         String   @db.VarChar(255)
  originalFileName String   @db.VarChar(255)
  contentType      String   @db.VarChar(100)
  fileSize         BigInt
  storageDisk      String   @db.VarChar(100)
  storagePath      String   @db.VarChar(500)
  publicUrl        String   @db.VarChar(500)
  uploadedByType   String   @db.VarChar(20)
  uploadedById     BigInt?
  createdAt        DateTime @default(now())
}

model ContractReferralReward {
  id                    BigInt       @id @default(autoincrement())
  contractId            BigInt
  contractedUserId      BigInt
  referrerUserId        BigInt
  referralRelationId    BigInt
  rewardMonth           String       @db.Char(7)
  baseMonthlyFee        Decimal      @db.Decimal(10, 2)
  rewardRate            Decimal      @db.Decimal(5, 4)
  rewardPoints          Int
  calculationTargetDate DateTime
  status                RewardStatus @default(scheduled)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  contract MobileContract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@unique([contractId, referrerUserId, rewardMonth])
  @@index([contractedUserId])
  @@index([referrerUserId])
}

model MonthlyRewardRun {
  id                BigInt   @id @default(autoincrement())
  rewardMonth       String   @db.Char(7)
  closingDate       DateTime
  mode              String   @db.VarChar(20)
  totalContracts    Int      @default(0)
  totalReferrers    Int      @default(0)
  totalRewardPoints Int      @default(0)
  executedByAdminId BigInt?
  createdAt         DateTime @default(now())
}

model PointWallet {
  id                     BigInt   @id @default(autoincrement())
  userId                 BigInt   @unique
  autoPointsBalance      Int      @default(0)
  manualPointsBalance    Int      @default(0)
  externalPointsBalance  Int      @default(0)
  availablePointsBalance Int      @default(0)
  usedPointsBalance      Int      @default(0)
  expiredPointsBalance   Int      @default(0)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PointTransaction {
  id              BigInt               @id @default(autoincrement())
  userId          BigInt
  transactionType PointTransactionType
  pointSourceType PointSourceType
  points          Int
  balanceAfter    Int
  relatedUserId   BigInt?
  relatedContractId BigInt?
  description     String?              @db.VarChar(255)
  occurredAt      DateTime
  createdByType   String               @db.VarChar(20)
  createdById     BigInt?
  createdAt       DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([relatedContractId])
}

model PointUsage {
  id                  BigInt   @id @default(autoincrement())
  userId              BigInt
  orderId             BigInt?
  usedAutoPoints      Int      @default(0)
  usedManualPoints    Int      @default(0)
  usedExternalPoints  Int      @default(0)
  totalUsedPoints     Int
  usedAt              DateTime
  createdAt           DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order Order? @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([orderId])
}

model Product {
  id          BigInt   @id @default(autoincrement())
  name        String   @unique @db.VarChar(255)
  description String?  @db.VarChar(500)
  price       Int
  imageUrl    String?  @db.VarChar(500)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderItems OrderItem[]
}

model Order {
  id             BigInt   @id @default(autoincrement())
  userId         BigInt
  orderNumber    String   @unique @db.VarChar(100)
  status         String   @db.VarChar(30)
  subtotalAmount Int
  usedPoints     Int      @default(0)
  totalAmount    Int
  orderedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      OrderItem[]
  pointUsages PointUsage[]

  @@index([userId])
}

model OrderItem {
  id          BigInt   @id @default(autoincrement())
  orderId     BigInt
  productId   BigInt
  productName String   @db.VarChar(255)
  unitPrice   Int
  quantity    Int
  lineAmount  Int
  createdAt   DateTime @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model TravelSubscription {
  id             BigInt         @id @default(autoincrement())
  userId         BigInt
  planName       String         @db.VarChar(255)
  level          Int            @default(1)           // 1〜5
  pricingTier    String         @default("early") @db.VarChar(20) // "early"=初回50名, "standard"=51名〜
  monthlyFee     Decimal        @db.Decimal(10, 2)
  status         ContractStatus @default(pending)
  forceStatus    String         @default("none") @db.VarChar(20) // "none"|"forced_active"|"forced_inactive"
  startedAt      DateTime?
  confirmedAt    DateTime?
  canceledAt     DateTime?
  note           String?        @db.VarChar(500)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model AdminAuditLog {
  id          BigInt   @id @default(autoincrement())
  adminId     BigInt?
  actionType  String   @db.VarChar(100)
  targetTable String   @db.VarChar(100)
  targetId    String?  @db.VarChar(100)
  beforeJson  Json?
  afterJson   Json?
  createdAt   DateTime @default(now())
}

model SiteSetting {
  id           BigInt   @id @default(autoincrement())
  settingKey   String   @unique @db.VarChar(100)
  settingValue String?  @db.VarChar(1000)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
model Announcement {
  id          String   @id @default(cuid())
  title       String
  content     String   @db.Text
  tag         String   @default("notice") // "important" | "campaign" | "new" | "notice"
  isPublished Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("announcements")
}
enum VpPhoneApplicationStatus {
  pending
  reviewing
  contracted
  rejected
  canceled
}

model VpPhoneApplication {
  id              BigInt                     @id @default(autoincrement())
  userId          BigInt
  // 申込者情報
  nameKanji       String                     @db.VarChar(100)
  nameKana        String                     @db.VarChar(100)
  email           String                     @db.VarChar(255)
  password        String?                    @db.VarChar(255)
  phone           String                     @db.VarChar(30)
  birthDate       String                     @db.VarChar(20)
  gender          String                     @db.VarChar(10)
  lineId          String?                    @db.VarChar(100)
  lineDisplayName String?                    @db.VarChar(100)
  // 紹介者情報
  referrerCode    String?                    @db.VarChar(100)
  referrerName    String?                    @db.VarChar(100)
  // 希望プラン種別: voice=音声回線契約, data=大容量データ回線契約
  contractType    String?                    @db.VarChar(50)
  desiredPlan     String?                    @db.VarChar(255)
  // 管理情報
  status          VpPhoneApplicationStatus   @default(pending)
  adminNote       String?                    @db.VarChar(500)
  reviewedAt      DateTime?
  reviewedByAdminId BigInt?
  contractedAt    DateTime?
  // 紐づく携帯契約（審査完了後に設定）
  mobileContractId BigInt?                   @unique
  createdAt       DateTime                   @default(now())
  updatedAt       DateTime                   @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  mobileContract MobileContract? @relation(fields: [mobileContractId], references: [id])

  @@index([userId])
  @@index([status])
  @@map("vp_phone_applications")
}

model MobileContract {
  id              BigInt         @id @default(autoincrement())
  userId          BigInt
  referrerId      BigInt?
  contractNumber  String?        @db.VarChar(100)
  planName        String         @db.VarChar(255)
  monthlyFee      Decimal        @default(0) @db.Decimal(10, 2)
  status          ContractStatus @default(pending)
  startedAt       DateTime?
  confirmedAt     DateTime?
  canceledAt      DateTime?
  note            String?        @db.VarChar(500)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  user             User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrer         User?                    @relation("ReferrerContracts", fields: [referrerId], references: [id])
  referralRewards  ContractReferralReward[]
  vpPhoneApplication VpPhoneApplication?

  @@index([userId])
  @@index([status])
  @@index([referrerId])
  @@map("mobile_contracts")
}

// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
// MLM（CLAIR仕様）専用モデル
// ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

/// 会員タイプ（ビジネス会員 / 愛用会員）
enum MlmMemberType {
  business   // ビジネス会員（ボーナス取得権あり）
  preferred  // 愛用会員（ボーナス取得権なし）
}

/// 会員ステータス
enum MlmMemberStatus {
  active      // 活動中
  autoship    // オートシップのみ
  lapsed      // 失効
  suspended   // 停止
  withdrawn   // 退会
  midCancel   // 中途解約
}

/// ボーナス計算実行ステータス
enum BonusRunStatus {
  draft      // 下書き（計算中）
  confirmed  // 確定（結果公開済み）
  canceled   // 取消
}

/// ボーナス種別
enum BonusType {
  direct       // ダイレクトボーナス
  unilevel     // ユニレベルボーナス
  structure    // 組織構築ボーナス
  savings      // 貯金ボーナス
}

/// MLM会員情報（CLAIRホールディングス仕様）
model MlmMember {
  id                BigInt          @id @default(autoincrement())
  userId            BigInt          @unique
  memberCode        String          @unique @db.VarChar(50)  // 6桁-枝番（例: 123456-01）
  memberType        MlmMemberType   @default(business)
  status            MlmMemberStatus @default(active)
  // 組織構造
  uplineId          BigInt?                                  // 直上者（マトリックス）
  referrerId        BigInt?                                  // 紹介者（ユニレベル）
  matrixPosition    Int             @default(0)              // 直下での位置（1〜6）
  // レベル関連
  currentLevel      Int             @default(0)              // 0=なし, 1〜5
  titleLevel        Int             @default(0)              // 称号レベル（過去最高）
  conditionAchieved Boolean         @default(false)          // 条件達成フラグ
  forceActive       Boolean         @default(false)          // 強制アクティブ
  forceLevel        Int?                                     // 強制レベル
  // 契約日
  contractDate      DateTime?                                // 契約締結日（アクティブ判定①）
  // オートシップ
  autoshipEnabled   Boolean         @default(false)
  autoshipStopDate  DateTime?
  autoshipSuspendMonths String?     @db.VarChar(100)         // カンマ区切り "2025-01,2025-02"
  // 貯金ポイント累計
  savingsPoints     Int             @default(0)
  note              String?         @db.VarChar(500)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  upline            MlmMember?      @relation("MatrixDownline", fields: [uplineId], references: [id])
  downlines         MlmMember[]     @relation("MatrixDownline")
  referrer          MlmMember?      @relation("UniLevelReferrals", fields: [referrerId], references: [id])
  referrals         MlmMember[]     @relation("UniLevelReferrals")
  purchases         MlmPurchase[]
  bonusResults      BonusResult[]   @relation("BonusRecipient")

  @@index([uplineId])
  @@index([referrerId])
  @@index([status])
  @@map("mlm_members")
}

/// MLM購入記録（ポイント計算用）
model MlmPurchase {
  id              BigInt      @id @default(autoincrement())
  mlmMemberId     BigInt
  productCode     String      @db.VarChar(20)   // 商品コード (s1000, 1000, 1002, 2000 等)
  productName     String      @db.VarChar(255)
  quantity        Int         @default(1)
  unitPrice       Int                            // 税込金額（円）
  points          Int         @default(0)        // 商品ポイント
  totalPoints     Int         @default(0)        // quantity × points
  purchaseMonth   String      @db.Char(7)        // "YYYY-MM"
  purchasedAt     DateTime
  createdAt       DateTime    @default(now())

  mlmMember       MlmMember   @relation(fields: [mlmMemberId], references: [id], onDelete: Cascade)

  @@index([mlmMemberId])
  @@index([purchaseMonth])
  @@map("mlm_purchases")
}

/// ボーナス計算実行記録（月次）
model BonusRun {
  id                  BigInt          @id @default(autoincrement())
  bonusMonth          String          @db.Char(7)       // "YYYY-MM"
  closingDate         DateTime                          // 締め日
  status              BonusRunStatus  @default(draft)
  // 集計結果
  totalMembers        Int             @default(0)
  totalActiveMembers  Int             @default(0)
  totalBonusAmount    Int             @default(0)       // 総ボーナス支払額（円）
  // 実行情報
  executedByAdminId   BigInt?
  confirmedAt         DateTime?
  note                String?         @db.VarChar(500)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  results             BonusResult[]

  @@unique([bonusMonth])
  @@map("bonus_runs")
}

/// ボーナス計算結果（会員ごと）
model BonusResult {
  id                  BigInt      @id @default(autoincrement())
  bonusRunId          BigInt
  mlmMemberId         BigInt
  bonusMonth          String      @db.Char(7)       // "YYYY-MM"
  // アクティブ判定
  isActive            Boolean     @default(false)
  selfPurchasePoints  Int         @default(0)       // 自己購入pt
  groupPoints         Int         @default(0)       // グループpt（7段合計）
  directActiveCount   Int         @default(0)       // 直接紹介アクティブ数
  // レベル
  achievedLevel       Int         @default(0)       // 当月実績レベル (0〜5)
  previousTitleLevel  Int         @default(0)       // 旧レベル（計算前の称号）
  newTitleLevel       Int         @default(0)       // 新称号レベル（計算後）
  // ボーナス金額（円）
  directBonus         Int         @default(0)       // ダイレクトボーナス
  unilevelBonus       Int         @default(0)       // ユニレベルボーナス
  structureBonus      Int         @default(0)       // 組織構築ボーナス
  savingsBonus        Int         @default(0)       // 貯金ボーナス
  totalBonus          Int         @default(0)       // 合計
  // ユニレベルボーナス段数内訳（JSON）
  unilevelDetail      Json?                         // { "1": pt, "2": pt, ... }
  savingsPointsAdded  Int         @default(0)       // 今月追加貯金pt
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  bonusRun            BonusRun    @relation(fields: [bonusRunId], references: [id], onDelete: Cascade)
  mlmMember           MlmMember   @relation("BonusRecipient", fields: [mlmMemberId], references: [id], onDelete: Cascade)

  @@unique([bonusRunId, mlmMemberId])
  @@index([bonusMonth])
  @@index([mlmMemberId])
  @@map("bonus_results")
}

